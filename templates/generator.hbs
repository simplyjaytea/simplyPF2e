<div class="simplypf2e-generator">
  {{#unless hasApiKey}}
    <p class="notification warning">{{localize "SIMPLYPF2E.Generator.NoApiKey"}}</p>
  {{/unless}}

  <fieldset class="spf-inputs" {{#if busy}}disabled{{/if}}>
    <legend>{{localize "SIMPLYPF2E.Generator.ConceptLegend"}}</legend>
    <div class="form-group spf-preset">
      <label>{{localize "SIMPLYPF2E.Generator.Preset"}}</label>
      <div class="spf-preset-controls">
        <select name="preset">
          {{#each presets}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
        <button type="button" data-action="savePreset" data-tooltip="{{localize 'SIMPLYPF2E.Presets.SaveTooltip'}}">
          <i class="fa-solid fa-plus"></i>
        </button>
        <button type="button" data-action="deletePreset" data-tooltip="{{localize 'SIMPLYPF2E.Presets.DeleteTooltip'}}" {{#unless selectedPresetIsCustom}}disabled{{/unless}}>
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
    </div>
    <div class="form-group stacked">
      {{#if randomSelected}}
        <p class="spf-hint spf-random-hint">
          <i class="fa-solid fa-dice"></i> {{localize "SIMPLYPF2E.Generator.RandomHint"}}
        </p>
      {{else}}
        <label>{{localize "SIMPLYPF2E.Generator.Prompt"}}</label>
        <textarea name="prompt" rows="3" placeholder="{{promptPlaceholder}}">{{input.prompt}}</textarea>
      {{/if}}
    </div>
    <div class="spf-row">
      <div class="form-group">
        <label>{{localize "SIMPLYPF2E.Generator.Level"}}</label>
        <div class="spf-level-controls">
          <button type="button" data-action="levelDown" data-tooltip="{{localize 'SIMPLYPF2E.Generator.LevelDown'}}">
            <i class="fa-solid fa-minus"></i>
          </button>
          <input type="number" name="level" min="-1" max="24" step="1" value="{{input.level}}">
          <button type="button" data-action="levelUp" data-tooltip="{{localize 'SIMPLYPF2E.Generator.LevelUp'}}">
            <i class="fa-solid fa-plus"></i>
          </button>
        </div>
      </div>
      <div class="form-group">
        <label>{{localize "SIMPLYPF2E.Generator.Rarity"}}</label>
        <select name="rarity">
          {{#each rarities}}
            <option value="{{this.value}}" {{#if (eq this.value @root.input.rarity)}}selected{{/if}}>{{localize this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group spf-checkbox">
        <label>
          <input type="checkbox" name="allowSpellcasting" {{#if input.allowSpellcasting}}checked{{/if}}>
          {{localize "SIMPLYPF2E.Generator.AllowSpellcasting"}}
        </label>
      </div>
    </div>
    <button type="button" data-action="generate" {{#if busy}}disabled{{/if}}>
      <i class="fa-solid fa-wand-sparkles"></i>
      {{#if preview}}{{localize "SIMPLYPF2E.Generator.Regenerate"}}{{else}}{{localize "SIMPLYPF2E.Generator.Generate"}}{{/if}}
    </button>
  </fieldset>

  {{#if busy}}
    {{#if progress}}
      <div class="spf-progress">
        <div class="spf-progress-bar">
          <div class="spf-progress-fill" style="width: {{progress.percent}}%"></div>
        </div>
        <ol class="spf-progress-steps">
          {{#each progress.steps}}
            <li class="spf-step-{{this.state}}">
              {{#if (eq this.state "done")}}<i class="fa-solid fa-check"></i>{{/if}}
              {{#if (eq this.state "active")}}<i class="fa-solid fa-spinner fa-spin"></i>{{/if}}
              {{localize this.label}}
            </li>
          {{/each}}
        </ol>
        <p class="spf-progress-detail">{{progress.detail}}</p>
        <p class="spf-model">{{model}}</p>
      </div>
    {{else}}
      <div class="spf-busy">
        <i class="fa-solid fa-spinner fa-spin"></i>
        {{localize "SIMPLYPF2E.Generator.Busy"}} <span class="spf-model">({{model}})</span>
      </div>
    {{/if}}
  {{/if}}

  {{#if error}}
    <p class="notification error">{{error}}</p>
  {{/if}}

  {{#if preview}}
  <section class="spf-preview">
    <header class="spf-statblock-header">
      <h2>{{preview.concept.name}}</h2>
      <span class="spf-level">{{localize "SIMPLYPF2E.Generator.Creature"}} {{preview.concept.level}}</span>
    </header>
    {{#if preview.concept.blurb}}<p class="spf-blurb"><em>{{preview.concept.blurb}}</em></p>{{/if}}
    <div class="spf-traits">
      {{#each preview.traits}}<span class="spf-trait">{{this}}</span>{{/each}}
    </div>

    <div class="spf-statline">
      <span><strong>{{localize "SIMPLYPF2E.Preview.Perception"}}</strong> +{{preview.stats.perception}}{{#if preview.senses}}; {{preview.senses}}{{/if}}</span>
      {{#if preview.languages}}<span><strong>{{localize "SIMPLYPF2E.Preview.Languages"}}</strong> {{preview.languages}}</span>{{/if}}
      {{#if preview.stats.skills.length}}
        <span><strong>{{localize "SIMPLYPF2E.Preview.Skills"}}</strong>
          {{#each preview.stats.skills}}{{this.name}} +{{this.mod}}{{#unless @last}}, {{/unless}}{{/each}}
        </span>
      {{/if}}
    </div>

    <div class="spf-statline spf-defenses">
      <span><strong>AC</strong> {{preview.stats.ac}}</span>
      <span><strong>{{localize "SIMPLYPF2E.Preview.Fort"}}</strong> +{{preview.stats.saves.fortitude}}</span>
      <span><strong>{{localize "SIMPLYPF2E.Preview.Ref"}}</strong> +{{preview.stats.saves.reflex}}</span>
      <span><strong>{{localize "SIMPLYPF2E.Preview.Will"}}</strong> +{{preview.stats.saves.will}}</span>
      <span><strong>HP</strong> {{preview.stats.hp}}</span>
    </div>
    {{#if preview.iwr.immunities}}<div class="spf-statline"><span><strong>{{localize "SIMPLYPF2E.Preview.Immunities"}}</strong> {{preview.iwr.immunities}}</span></div>{{/if}}
    {{#if preview.iwr.resistances}}<div class="spf-statline"><span><strong>{{localize "SIMPLYPF2E.Preview.Resistances"}}</strong> {{preview.iwr.resistances}}</span></div>{{/if}}
    {{#if preview.iwr.weaknesses}}<div class="spf-statline"><span><strong>{{localize "SIMPLYPF2E.Preview.Weaknesses"}}</strong> {{preview.iwr.weaknesses}}</span></div>{{/if}}

    <div class="spf-statline">
      <span><strong>{{localize "SIMPLYPF2E.Preview.Speed"}}</strong> {{preview.speeds}}</span>
    </div>

    <div class="spf-strikes">
      {{#each preview.stats.strikes}}
        <div class="spf-strike">
          <strong>{{#if (eq this.type "ranged")}}{{localize "SIMPLYPF2E.Preview.Ranged"}}{{else}}{{localize "SIMPLYPF2E.Preview.Melee"}}{{/if}}</strong>
          {{this.name}} +{{this.bonus}},
          <strong>{{localize "SIMPLYPF2E.Preview.Damage"}}</strong> {{this.damage}} {{this.damageType}}
          {{#if this.average}}(avg {{this.average}}){{/if}}
          {{#if this.traits.length}}<span class="spf-strike-traits">({{#each this.traits}}{{this}}{{#unless @last}}, {{/unless}}{{/each}})</span>{{/if}}
        </div>
      {{/each}}
    </div>

    {{#if preview.abilities.length}}
      <h3>{{localize "SIMPLYPF2E.Preview.Abilities"}}</h3>
      <ul class="spf-list">
        {{#each preview.abilities}}
          <li>
            <strong>{{this.name}}</strong>
            {{#if this.fromGlossary}}
              <span class="spf-found" title="{{localize 'SIMPLYPF2E.Preview.FromCompendium'}}"><i class="fa-solid fa-book"></i> {{this.glossaryName}}</span>
            {{else}}
              <span class="spf-custom">{{localize "SIMPLYPF2E.Preview.Custom"}}</span>
              {{#if this.description}}<div class="spf-ability-desc">{{this.description}}</div>{{/if}}
            {{/if}}
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if preview.concept.spellcasting}}
      <h3>{{localize "SIMPLYPF2E.Preview.Spells"}}
        <span class="spf-spell-dc">DC {{preview.stats.spellDC}}, {{localize "SIMPLYPF2E.Preview.Attack"}} +{{preview.stats.spellAttack}} ({{preview.concept.spellcasting.tradition}})</span>
      </h3>
      <ul class="spf-list spf-inline">
        {{#each preview.spells}}
          <li class="{{#unless this.found}}spf-missing{{/unless}}">
            {{this.name}} <span class="spf-rank">({{#if this.rank}}{{localize "SIMPLYPF2E.Preview.Rank"}} {{this.rank}}{{else}}{{localize "SIMPLYPF2E.Preview.Cantrip"}}{{/if}})</span>
            {{#unless this.found}}<i class="fa-solid fa-triangle-exclamation" title="{{localize 'SIMPLYPF2E.Preview.NotFound'}}"></i>{{/unless}}
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if preview.feats.length}}
      <h3>{{localize "SIMPLYPF2E.Preview.Feats"}}</h3>
      <ul class="spf-list spf-inline">
        {{#each preview.feats}}
          <li class="{{#unless this.found}}spf-missing{{/unless}}">
            {{this.name}}
            {{#unless this.found}}<i class="fa-solid fa-triangle-exclamation" title="{{localize 'SIMPLYPF2E.Preview.NotFound'}}"></i>{{/unless}}
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if preview.equipment.length}}
      <h3>{{localize "SIMPLYPF2E.Preview.Equipment"}}</h3>
      <ul class="spf-list spf-inline">
        {{#each preview.equipment}}
          <li class="{{#unless this.found}}spf-missing{{/unless}}">
            {{this.name}}
            {{#unless this.found}}<i class="fa-solid fa-triangle-exclamation" title="{{localize 'SIMPLYPF2E.Preview.NotFound'}}"></i>{{/unless}}
          </li>
        {{/each}}
      </ul>
    {{/if}}

    {{#if preview.concept.description}}
      <h3>{{localize "SIMPLYPF2E.Preview.Description"}}</h3>
      <p class="spf-description">{{preview.concept.description}}</p>
    {{/if}}

    <footer class="spf-actions">
      <button type="button" data-action="createActor" {{#if busy}}disabled{{/if}}>
        <i class="fa-solid fa-user-plus"></i> {{localize "SIMPLYPF2E.Generator.CreateActor"}}
      </button>
      <button type="button" data-action="discard" {{#if busy}}disabled{{/if}}>
        <i class="fa-solid fa-trash"></i> {{localize "SIMPLYPF2E.Generator.Discard"}}
      </button>
    </footer>
  </section>
  {{/if}}
</div>
